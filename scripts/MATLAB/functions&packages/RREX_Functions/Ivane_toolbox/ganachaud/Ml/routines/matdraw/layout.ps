/dispDotDict 12 dict dup begin 
/dx [0 1 1 0] def
/dy [0 1 0 1] def
/size 0 def
/nShades 0 def
/theMatrix null def
/lv 0 def
/ilv 0 def
/quadSize 0 def
/quadrant 0 def
/place 0 def
/x 0 def
/y 0 def
end def
/MakeDispDotMatrix {
dispDotDict begin
/dx [0 1 1 0] def 
/dy [0 1 0 1] def
/size exch def 
/nShades size size mul def 
/theMatrix nShades array def 
0 1 nShades 1 sub { 
/lv exch def 
/ilv lv def 
/place nShades 4 idiv	def 
/quadSize 1 def 
/x 0 def /y 0 def 
{
place 0 eq {exit} if 
/quadrant ilv place idiv def 
/ilv ilv quadrant place mul sub def 
/x x dx quadrant get quadSize mul add def	
/y y dy quadrant get quadSize mul add def	
/place place 4 idiv def 
/quadSize quadSize 2 mul def 
} loop
theMatrix 
y size mul x add 
lv put
} for
end
} Bdef
/FrequencyToMatrixSize {
1 1 matrix defaultmatrix dtransform pop 72 mul abs 
exch div 
0 5 { 
dup 2 exch exp 
2 index 
gt { 
exit 
} if
1 add 
} repeat
1 sub
exch pop 
2 exch exp cvi
} Bdef
/HalftoneDotFunctions 8 dict dup 3 -1 roll Xdef begin
/TriangleDotFunction {
2 div /@2 Xdef 
dup 0 lt {neg} if 2 div /@1 Xdef 
2 @2 sub 2 @1 mul sub
2.5 div 
} Bdef
/SpiralDotFunction {
2 div /@2 Xdef 
2 div /@1 Xdef 
1 @1 dup mul @2 dup mul @1 16 div @2 8 div add add add sub
} Bdef
/SquareDotFunction {
/@2 Xdef /@1 Xdef 
@1 @2 lt {@2} {@1} ifelse
1 exch sub	
2 div 
} Bdef
/RoundDotFunction {
abs /@2 Xdef 
abs /@1 Xdef 
@1 @2 add 1 gt {
/@1 1 @1 sub def 
/@2 1 @2 sub def
@1 @1 mul
@2 @2 mul
add
1 sub
} {
1
@1 @1 mul
@2 @2 mul
sub
sub
} ifelse
2 div 
} Bdef
/EllipticDotFunction {
/@2 Xdef
/@1 Xdef
/@2 @2 2 mul abs def 
/@1 @1 @1 mul def 
/@1 @1 @2 add def 
/@1 @1 3 div def 
1 @1 sub
2 div 
} Bdef
/LineDotFunction {
exch pop	
} Bdef
/DispersedDotFunction {
dispDotDict begin
1 add 2 div size mul cvi exch 
1 add 2 div size mul cvi exch 
size mul add 
theMatrix exch get	
nShades div 
end
} Bdef
end 
